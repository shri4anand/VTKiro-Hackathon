{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["api/**/*", "backend/src/**/*"],
  "exclude": [
    "node_modules",
    "frontend",
    "backend/dist",
    "backend/node_modules",
    "backend/src/__tests__",
    "backend/src/index.ts"
  ]
}
