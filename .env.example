# ClearSignal — Required Environment Variables
# Copy this file to .env.local for local development
# In Vercel, add these via the project dashboard (Settings → Environment Variables)

# OpenAI API key for text simplification
LLM_API_KEY=your_openai_api_key_here

# OpenAI model to use (default: gpt-5.4-mini)
LLM_MODEL=gpt-5.4-mini

# Hume AI API key for text-to-speech
HUME_API_KEY=your_hume_api_key_here

# --- Local development only ---
# Override the API base URL when running the Express backend locally.
# Leave unset in Vercel — the frontend calls /api/* relative to the same domain.
# VITE_API_URL=http://localhost:3001
